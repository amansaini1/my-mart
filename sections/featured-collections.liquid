{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{%- liquid
  assign collection = section.settings.collection
  assign products_to_show = section.settings.products_to_show
-%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="featured-collections page-width section-{{ section.id }}-padding{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">

    {%- unless section.settings.title == blank -%}
      <div class="featured-collections__header">
        <h2 class="featured-collections__title {{ section.settings.heading_size }}">
          {{ section.settings.title | escape }}
        </h2>
        {%- if section.settings.show_view_all and collection != blank -%}
          <a href="{{ collection.url }}" class="link">
            {{ 'sections.featured_collection.view_all' | t }}
            <span aria-hidden="true"> &rarr;</span>
          </a>
        {%- endif -%}
      </div>
    {%- endunless -%}

    {%- if collection != blank and collection.products_count > 0 -%}
      <ul
        class="featured-collections__grid grid grid--2-col-tablet-down grid--4-col-desktop list-unstyled"
        role="list"
      >
        {%- for product in collection.products limit: products_to_show -%}
          <li
            class="featured-collections__item grid__item{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}"
            style="--animation-order: {{ forloop.index }};"
          >
            <article class="featured-collections__card card">
              <a href="{{ product.url }}" class="featured-collections__card-link">
                <div class="featured-collections__media card__media">
                  {%- if product.featured_media -%}
                    {{
                      product.featured_media
                      | image_url: width: 600
                      | image_tag:
                        loading: 'lazy',
                        class: 'featured-collections__product-image motion-reduce',
                        widths: '165, 360, 533, 720',
                        sizes: '(min-width: 1200px) 267px, (min-width: 750px) calc((100vw - 130px) / 4), calc((100vw - 30px) / 2)',
                        alt: product.featured_media.alt | escape
                    }}
                  {%- else -%}
                    {{ 'product-1' | placeholder_svg_tag: 'featured-collections__placeholder' }}
                  {%- endif -%}
                </div>
                <div class="featured-collections__info card-information">
                  <h3 class="featured-collections__product-title card-information__text h5">
                    {{ product.title | escape }}
                  </h3>
                  <div class="featured-collections__price price">
                    {%- liquid
                      assign money_price = product.price | money_with_currency
                      if product.price_varies
                        assign money_price = product.price_min | money_with_currency
                        assign price_display = 'products.product.price.from_price_html' | t: price: money_price
                      else
                        assign price_display = money_price
                      endif
                    -%}
                    <span class="price-item price-item--regular">{{ price_display }}</span>
                    {%- if product.compare_at_price > product.price -%}
                      <s class="price-item price-item--regular">{{ product.compare_at_price | money_with_currency }}</s>
                    {%- endif -%}
                  </div>
                </div>
              </a>
            </article>
          </li>
        {%- endfor -%}
      </ul>
    {%- elsif collection == blank -%}
      <p class="featured-collections__empty">Select a collection in the theme editor.</p>
    {%- else -%}
      <p class="featured-collections__empty">This collection has no products yet.</p>
    {%- endif -%}

  </div>
</div>

<style>
  .featured-collections__header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 2.4rem;
  }

  .featured-collections__title {
    margin: 0;
  }

  .featured-collections__grid {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .featured-collections__card {
    border: 0;
  }

  .featured-collections__card-link {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .featured-collections__card-link:hover .featured-collections__product-title {
    text-decoration: underline;
  }

  .featured-collections__media {
    aspect-ratio: 1;
    overflow: hidden;
    border-radius: var(--media-border-radius, 0);
    margin-bottom: 1.2rem;
  }

  .featured-collections__product-image,
  .featured-collections__placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }

  .featured-collections__card-link:hover .featured-collections__product-image {
    transform: scale(1.04);
  }

  .featured-collections__info {
    padding: 0 0.4rem;
  }

  .featured-collections__product-title {
    margin-bottom: 0.4rem;
  }

  .featured-collections__price {
    font-size: 1.4rem;
  }

  .featured-collections__empty {
    text-align: center;
    padding: 4rem 0;
    color: inherit;
    opacity: 0.6;
  }
</style>

{% schema %}
{
  "name": "Featured Collections",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Featured Collection"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" }
      ],
      "default": "h1"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 12,
      "step": 2,
      "default": 8,
      "label": "Products to show"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show \"View all\" link",
      "default": true
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Featured Collections"
    }
  ]
}
{% endschema %}
