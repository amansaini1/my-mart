{%- style -%}
  .shop-range {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background: {{ section.settings.background_color }};
  }

  .shop-range__heading {
    font-size: 2.8rem;
    font-weight: 700;
    margin: 0 0 3.2rem;
    color: #1a1a1a;
    letter-spacing: -0.02em;
  }

  .shop-range__grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);
    gap: 2.4rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .shop-range__card {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .shop-range__card:hover .shop-range__image {
    transform: scale(1.04);
  }

  .shop-range__media {
    border-radius: {{ section.settings.border_radius }}px;
    overflow: hidden;
    aspect-ratio: {{ section.settings.image_ratio }};
    background: #f5f5f5;
    margin-bottom: 1.6rem;
  }

  .shop-range__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .shop-range__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #efefef;
  }

  .shop-range__placeholder svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .shop-range__info {
    text-align: {{ section.settings.text_align }};
    padding: 0 0.4rem;
  }

  .shop-range__name {
    font-size: 1.7rem;
    font-weight: 700;
    margin: 0 0 0.4rem;
    color: #1a1a1a;
    letter-spacing: -0.01em;
  }

  .shop-range__count {
    font-size: 1.4rem;
    color: #6b6b6b;
    margin: 0;
  }

  @media screen and (max-width: 989px) {
    .shop-range__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.6rem;
    }
    .shop-range__heading {
      font-size: 2.2rem;
    }
  }

  @media screen and (max-width: 749px) {
    .shop-range {
      padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    }
    .shop-range__grid {
      grid-template-columns: repeat({{ section.settings.columns_mobile }}, 1fr);
      gap: 1.2rem;
    }
    .shop-range__name {
      font-size: 1.5rem;
    }
  }
{%- endstyle -%}

<div class="shop-range">
  <div class="page-width">

    {%- unless section.settings.title == blank -%}
      <h2 class="shop-range__heading">{{ section.settings.title | escape }}</h2>
    {%- endunless -%}

    {%- if section.blocks.size > 0 -%}
      <ul class="shop-range__grid" role="list">
        {%- for block in section.blocks -%}
          {%- assign col = block.settings.collection -%}
          <li {{ block.shopify_attributes }}>
            <a
              href="{{ col.url | default: routes.collections_url }}"
              class="shop-range__card"
              aria-label="{{ col.title | default: 'Collection' | escape }}"
            >
              <div class="shop-range__media">
                {%- if col.featured_image -%}
                  {%- assign img_sizes = '(min-width: 750px) 25vw, 50vw' -%}
                  {{
                    col.featured_image
                    | image_url: width: 800
                    | image_tag:
                      class: 'shop-range__image motion-reduce',
                      loading: 'lazy',
                      widths: '360, 533, 800',
                      sizes: img_sizes,
                      alt: col.featured_image.alt | default: col.title | escape
                  }}
                {%- else -%}
                  <div class="shop-range__placeholder">
                    {{ 'collection-1' | placeholder_svg_tag }}
                  </div>
                {%- endif -%}
              </div>

              <div class="shop-range__info">
                <p class="shop-range__name">
                  {{ col.title | default: block.settings.label | escape }}
                </p>
                {%- if section.settings.show_product_count -%}
                  <p class="shop-range__count">
                    {{ col.products_count | default: 0 }}
                    {{ col.products_count | pluralize: 'Product', 'Products' }}
                  </p>
                {%- endif -%}
              </div>
            </a>
          </li>
        {%- endfor -%}
      </ul>
    {%- endif -%}

  </div>
</div>

{% schema %}
{
  "name": "Shop Our Range",
  "tag": "section",
  "class": "section",
  "max_blocks": 8,
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Shop Our Range"
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Text alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "left"
    },
    {
      "type": "checkbox",
      "id": "show_product_count",
      "label": "Show product count",
      "default": true
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image ratio",
      "options": [
        { "value": "1 / 1", "label": "Square (1:1)" },
        { "value": "3 / 4", "label": "Portrait (3:4)" },
        { "value": "4 / 3", "label": "Landscape (4:3)" }
      ],
      "default": "3 / 4"
    },
    {
      "type": "range",
      "id": "border_radius",
      "min": 0,
      "max": 32,
      "step": 2,
      "unit": "px",
      "label": "Image corner radius",
      "default": 12
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 6,
      "step": 1,
      "label": "Columns on desktop",
      "default": 4
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columns on mobile",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ],
      "default": "2"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 52
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 52
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Fallback label",
          "info": "Shown if no collection is selected"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shop Our Range",
      "blocks": [
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" }
      ]
    }
  ]
}
{% endschema %}
